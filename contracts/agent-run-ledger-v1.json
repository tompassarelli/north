{
  "version": "north-agent-run-ledger:v1",
  "coverage": ["exact", "partial", "unknown"],
  "eventTypes": {
    "admission_received": {
      "required": ["receiptDigest"],
      "allowed": ["receiptDigest", "policyVersion"]
    },
    "provider_routed": {
      "required": ["provider", "account", "model", "effort"],
      "allowed": ["provider", "account", "model", "effort", "reasonCode"]
    },
    "prompt_constructed": {
      "required": [
        "compositionVersion", "compositionDigest", "capabilityClass", "capabilityCount",
        "stablePrefixBytes", "uniqueTailBytes", "totalBytes", "byteMeasurementSource",
        "tokenMeasurementStatus", "tokenMeasurementSource", "contextWindowStatus",
        "contextWindowSource", "contextBudgetStatus", "contextBudgetSource",
        "compactionPolicy", "compactionPolicyVersion"
      ],
      "allowed": [
        "compositionVersion", "compositionDigest", "capabilityClass", "capabilityCount",
        "stablePrefixBytes", "uniqueTailBytes", "totalBytes", "byteMeasurementSource",
        "stablePrefixTokens", "uniqueTailTokens", "totalCompositionTokens",
        "tokenMeasurementStatus", "tokenMeasurementSource", "providerContextWindowTokens",
        "contextWindowEffectiveFrom", "contextWindowStatus", "contextWindowSource",
        "effectiveContextBudgetTokens", "contextBudgetStatus", "contextBudgetSource",
        "compactionPolicy", "compactionPolicyVersion"
      ]
    },
    "tool_observed": {
      "required": ["toolName", "activity"],
      "allowed": ["toolName", "activity", "successCount", "errorCount"]
    },
    "usage_observed": {
      "required": ["terminalCount"],
      "allowed": ["inputTokens", "outputTokens", "totalTokens", "reasoningOutputTokens", "terminalCount"]
    },
    "cache_observed": {
      "required": [],
      "allowed": ["cacheReadTokens", "cacheCreateTokens", "cachedInputTokens"]
    },
    "compaction_observed": {
      "required": ["compactionCount", "compactionPolicy", "compactionPolicyVersion", "compactionEvidence"],
      "allowed": ["compactionCount", "compactionPolicy", "compactionPolicyVersion", "compactionEvidence"]
    },
    "escalation_observed": {
      "required": ["fromTier", "toTier", "reasonCode"],
      "allowed": ["fromTier", "toTier", "reasonCode"]
    },
    "child_settled": {
      "required": ["childRun", "childThread", "outcome"],
      "allowed": ["childRun", "childThread", "outcome", "settlementDigest"]
    },
    "terminal_cleanup": {
      "required": ["outcome", "cleanupStatus"],
      "allowed": ["outcome", "cleanupStatus", "childCount"]
    }
  },
  "fieldKinds": {
    "receiptDigest": "digest",
    "settlementDigest": "digest",
    "compositionDigest": "digest",
    "policyVersion": "identifier",
    "provider": "identifier",
    "account": "identifier",
    "model": "identifier",
    "effort": "identifier",
    "reasonCode": "identifier",
    "compositionVersion": "identifier",
    "capabilityClass": "identifier",
    "byteMeasurementSource": "identifier",
    "tokenMeasurementStatus": "identifier",
    "tokenMeasurementSource": "identifier",
    "contextWindowEffectiveFrom": "identifier",
    "contextWindowStatus": "identifier",
    "contextWindowSource": "identifier",
    "contextBudgetStatus": "identifier",
    "contextBudgetSource": "identifier",
    "compactionPolicy": "identifier",
    "compactionPolicyVersion": "identifier",
    "compactionEvidence": "identifier",
    "toolName": "identifier",
    "activity": "identifier",
    "fromTier": "identifier",
    "toTier": "identifier",
    "outcome": "identifier",
    "cleanupStatus": "identifier",
    "childRun": "entity",
    "childThread": "entity",
    "capabilityCount": "count",
    "stablePrefixBytes": "count",
    "uniqueTailBytes": "count",
    "totalBytes": "count",
    "stablePrefixTokens": "count",
    "uniqueTailTokens": "count",
    "totalCompositionTokens": "count",
    "providerContextWindowTokens": "count",
    "effectiveContextBudgetTokens": "count",
    "compactionCount": "count",
    "successCount": "count",
    "errorCount": "count",
    "inputTokens": "count",
    "outputTokens": "count",
    "totalTokens": "count",
    "reasoningOutputTokens": "count",
    "terminalCount": "count",
    "cacheReadTokens": "count",
    "cacheCreateTokens": "count",
    "cachedInputTokens": "count",
    "childCount": "count"
  },
  "privacy": {
    "maxIdentifierLength": 128,
    "forbiddenKeyFragments": [
      "prompt", "argument", "content", "message", "transcript", "secret",
      "tokenvalue", "apikey", "authorization", "credential", "raw"
    ]
  }
}
