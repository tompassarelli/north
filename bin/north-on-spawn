#!/usr/bin/env bash
# north-on-spawn — Claude Code / Codex SessionStart + SubagentStart hook.
# Registers the agent's presence on the north roster and injects the concern-
# coordination protocol into the new session via hookSpecificOutput.additionalContext
# — so an agent coordinates the moment it spawns, no human pasting anything.
# jq-free (jq isn't on PATH here). SessionStart cannot block startup; best-effort.
set -uo pipefail
IN="$(cat 2>/dev/null || true)"
# pull a flat JSON string field without jq
jget() { printf '%s' "$IN" | sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" | head -1; }
# `effort` is a structured common hook field: {"level":"xhigh"}. Restrict
# extraction to that object so an unrelated nested `level` can never become an
# identity claim.
jget_effort() {
  printf '%s' "$IN" | sed -n 's/.*"effort"[[:space:]]*:[[:space:]]*{[^}]*"level"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1
}
cwd="$(jget cwd)"; [ -z "$cwd" ] && cwd="$PWD"
sid="$(jget session_id)"
agent_id="$(jget agent_id)"
evt="$(jget hook_event_name)"; [ -z "$evt" ] && evt="SessionStart"
# SubagentStart carries a provider-owned `agent_id`; on Codex its session_id is
# explicitly the PARENT session. Keying presence/cache by that parent would
# collapse every native subagent onto one row. Prefer the actor id when present.
if [ "$evt" = "SubagentStart" ]; then
  identity_sid="${agent_id:-$sid}"
else
  identity_sid="$sid"
fi
if [ -z "$identity_sid" ] && [ -z "${NORTH_AGENT_ID:-}" ]; then
  exit 0
fi
identity_key_source="${identity_sid:-managed-${NORTH_AGENT_ID:-}}"
identity_key="$(printf '%s' "$identity_key_source" | sed 's/[^A-Za-z0-9._-]/_/g')"
identity_seed="${identity_key_source#agent-}"
REPO="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || echo "$cwd")"
RN="$(basename "$REPO")"
IDDIR="${XDG_RUNTIME_DIR:-/tmp}/north-agent-ids"
ROUTEDIR="${XDG_RUNTIME_DIR:-/tmp}/north-agent-routes"
DERIVED="session-$RN-${identity_seed:0:8}"

# Identity, de-aliased. INVARIANT: one live actor == one id; an id is only
# renewed/registered by the session that FIRST acquired it. An env pin
# (NORTH_AGENT_ID) is honored ONLY if no OTHER session already owns it. Otherwise
# it's an INHERITED pin — a parent's NORTH_AGENT_ID leaking into a subagent/child
# through the process environment: SubagentSessionStart fires with the subagent's
# OWN session_id but the parent's env, so honoring the pin would alias the parent
# id (2026-07-03: cc-fram-* had 3 workstreams + mail answered by the wrong actor).
# When the pin is already owned elsewhere, derive a distinct id from our own sid.
ID=""
pin="${NORTH_AGENT_ID:-}"
if [ -n "$pin" ]; then
  owned_by_other=0
  if [ -d "$IDDIR" ]; then
    for f in "$IDDIR"/*; do
      [ -e "$f" ] || continue                        # empty dir -> literal glob, skip
      [ "${f##*/}" = "$identity_key" ] && continue   # our own prior acquisition doesn't count
      [ "$(cat "$f" 2>/dev/null)" = "$pin" ] && { owned_by_other=1; break; }
    done
  fi
  [ "$owned_by_other" = 0 ] && ID="$pin"             # legit: fresh/first acquirer
fi
[ -z "$ID" ] && ID="$DERIVED"                        # inherited pin, or no pin at all

# pin identity for the session's lifetime: tooluse renews THIS id, whatever cwd later
# tool calls run in. Without the pin, identity flapped per (cwd-repo x session) and the
# roster flooded with phantoms (188 cc-after-text-* ghosts, 2026-07-02). Writing our
# OWN sid's file also stakes the acquisition, so a concurrent sibling subagent that reads
# the dir sees this id already owned and derives its own instead of aliasing.
if [ -n "$identity_key" ]; then
  mkdir -p "$IDDIR" 2>/dev/null && printf '%s' "$ID" > "$IDDIR/$identity_key" 2>/dev/null || true
fi

# register presence — best-effort, bounded; must never wedge a spawn.
# Canonical :7977 log (NOT the stranded :7978 daemon concern/roster/board never read).
timeout 5 bb "$HOME/code/north/cli/presence-cli.clj" "${NORTH_PORT:-7977}" register "$ID" "$REPO" "$ID" >/dev/null 2>&1 || true

# identity facts on @agent:<id> — ids stay meaningless; meaning lives in facts.
# Best-effort + bounded: a fact write must never wedge a spawn.
NORTHBIN="$HOME/code/north/bin/north"
PROVIDER=""
case "${AGENT_PROVIDER:-}" in
  anthropic|openai) PROVIDER="$AGENT_PROVIDER" ;; # explicit SDK/provider boundary
esac
if [ -z "$PROVIDER" ] && { [ -n "${CODEX_THREAD_ID:-}" ] || [ -n "${CODEX_CI:-}" ]; }; then
  PROVIDER="openai"
elif [ -z "$PROVIDER" ] && [ -n "${CLAUDECODE:-}" ]; then
  PROVIDER="anthropic"
fi
# SessionStart carries the active model on both provider surfaces. Claude
# tool-context hooks also expose effective effort; Codex hooks currently do not.
# Prefer exact hook observations over adapter env. `unobserved` is an explicit
# epistemic state, never an inferred model/effort/provider claim.
MODEL="$(jget model)"; [ -n "$MODEL" ] || MODEL="${AGENT_MODEL:-}"
EFFORT="$(jget_effort)"
[ -n "$EFFORT" ] || EFFORT="${CLAUDE_EFFORT:-${AGENT_REASONING:-${AGENT_EFFORT:-}}}"
PROVIDER_OBS="${PROVIDER:-unobserved}"
MODEL_OBS="${MODEL:-unobserved}"
EFFORT_OBS="${EFFORT:-unobserved}"
# Preserve the exact SessionStart observations independently from the route
# cache. The route cache is a convergence marker and must stay absent when any
# graph projection fails; this seed is evidence for the PostToolUse repair path,
# so Codex does not lose its observed provider merely because its later hook has
# no CODEX_* marker. It is never inferred from a model name.
if [ -n "$identity_key" ]; then
  route_seed="$ROUTEDIR/$identity_key.seed"
  seed_tmp="$ROUTEDIR/.$identity_key.$$.seed.tmp"
  if mkdir -p "$ROUTEDIR" 2>/dev/null &&
      printf '%s\n%s\n%s\n' "$PROVIDER_OBS" "$MODEL_OBS" "$EFFORT_OBS" > "$seed_tmp" 2>/dev/null; then
    mv -f "$seed_tmp" "$route_seed" 2>/dev/null || rm -f "$seed_tmp" 2>/dev/null || true
  fi
fi
slug() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9][^a-z0-9]*/-/g; s/^-//; s/-$//'
}
provider_segment="$(slug "$PROVIDER_OBS")"; [ -n "$provider_segment" ] || provider_segment="unobserved"
model_segment="$(slug "$MODEL_OBS")"; [ -n "$model_segment" ] || model_segment="unobserved"
effort_segment="$(slug "$EFFORT_OBS")"; [ -n "$effort_segment" ] || effort_segment="unobserved"
DISPLAY_HANDLE="$provider_segment-$model_segment-$effort_segment-native-${ID##*-}"
projection_ok=1
timeout 4 "$NORTHBIN" tell "agent:$ID" kind session >/dev/null 2>&1 || projection_ok=0
timeout 4 "$NORTHBIN" tell "agent:$ID" repo "$RN" >/dev/null 2>&1 || projection_ok=0
timeout 4 "$NORTHBIN" tell "agent:$ID" provider "$PROVIDER_OBS" >/dev/null 2>&1 || projection_ok=0
timeout 4 "$NORTHBIN" tell "agent:$ID" model "$MODEL_OBS" >/dev/null 2>&1 || projection_ok=0
timeout 4 "$NORTHBIN" tell "agent:$ID" effort "$EFFORT_OBS" >/dev/null 2>&1 || projection_ok=0
timeout 4 "$NORTHBIN" tell "agent:$ID" display_handle "$DISPLAY_HANDLE" >/dev/null 2>&1 || projection_ok=0
timeout 4 "$NORTHBIN" tell "agent:$ID" display_name "$DISPLAY_HANDLE" >/dev/null 2>&1 || projection_ok=0
# The route cache is change detection, not a source of inferred identity. Write
# it only after the effort + stored projections converged, so a failed write is
# retried by the next PostToolUse instead of being hidden by a premature cache hit.
if [ "$projection_ok" -eq 1 ] && [ -n "$identity_key" ]; then
  route_cache="$ROUTEDIR/$identity_key"
  route_tmp="$ROUTEDIR/.$identity_key.$$.tmp"
  if mkdir -p "$ROUTEDIR" 2>/dev/null &&
      printf '%s\n%s\n%s\n' "$PROVIDER_OBS" "$MODEL_OBS" "$EFFORT_OBS" > "$route_tmp" 2>/dev/null; then
    mv -f "$route_tmp" "$route_cache" 2>/dev/null || rm -f "$route_tmp" 2>/dev/null || true
  fi
fi

CTX="$(cat <<EOF
[north coordination active — you are agent "$ID" in repo "$RN"]
Other agents may be working here concurrently. You coordinate through CONCERNS, not locks —
work coexists; declaring never blocks. See who else is in your footprint, and shape your
feature against what is likely to land before it is in main.
  ~/code/north/bin/concern declare $ID $RN "<what you're building>" <file1,file2,...>
  ~/code/north/bin/concern overlap <your-id>   # who's in your footprint; likely-to-land marked -> build against it
  ~/code/north/bin/concern status <id> likely-to-land · done <id> · ls [repo]
Declare a concern before editing code for a feature, so others can see + shape around your work.

Internal notes / status / scratch / handoffs -> docs/private/ (gitignored), NEVER public docs/.
Run \`~/code/north/bin/ensure-private-docs\` to set up the ignore in a repo before writing there.

To be reachable in REAL TIME, arm your interrupt listener as a BACKGROUND task now:
  ~/code/north/bin/north listen $ID
Dormant (no tokens) until a peer addresses you; when it returns you have mail — read it, act, re-arm.
Ping a peer:  bb ~/code/north/cli/msg-cli.clj 7977 send $ID <peer-id> "URGENT" "<message>"
EOF
)"

# emit additionalContext as valid JSON (escape \  then "  then newlines -> \n)
esc="$(printf '%s' "$CTX" | sed 's/\\/\\\\/g; s/"/\\"/g' | sed ':a;N;$!ba;s/\n/\\n/g')"
printf '{"hookSpecificOutput":{"hookEventName":"%s","additionalContext":"%s"}}\n' "$evt" "$esc"
