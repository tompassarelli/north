#!/usr/bin/env bash
# north-mark-delegated — Claude Code PostToolUse hook for spawn/dispatch tools.
# When this session spawns a worker (mcp__north__spawn / mcp__north__dispatch /
# Task / Agent), stamp a per-session marker so the Stop hook (north-on-stop) knows
# this session has delegated work and must keep a listener armed to catch the
# worker's completion/death ping. WHY: the supervisor ends its turn after
# delegating (correct — never blocks), but a yielded turn only gets re-woken by an
# ARMED background listener; without one, a worker's ping lands in a dead inbox and
# the session goes silent until a human pokes it (the 2026-07-11 failure).
# Best-effort, always exits 0 — must NEVER break a tool call.
set -uo pipefail
umask 077
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ACTOR_KEY="$SCRIPT_DIR/north-actor-key"

# This hook has no provider-visible output. Bound the whole implementation so a
# blocked stdin, hostile cwd/git lookup, or slow filesystem degrades to a clean
# no-op well before the provider's 10s PostToolUse deadline.
if [ "${NORTH_MARK_DELEGATED_INNER:-0}" != 1 ]; then
  NORTH_MARK_DELEGATED_INNER=1 timeout --signal=TERM --kill-after=0.2s 2s \
    "$0" >/dev/null 2>&1 || true
  exit 0
fi

PARSED="$(python3 -c '
import json, sys
try:
    data = json.load(sys.stdin)
    for key in ("cwd", "session_id", "agent_id"):
        value = data.get(key, "")
        value = value if isinstance(value, str) else ""
        print(value.replace("\n", "").replace("\r", ""))
except Exception:
    pass
' 2>/dev/null || true)"
mapfile -t JFIELDS <<<"$PARSED"
cwd="${JFIELDS[0]:-}"; [ -z "$cwd" ] && cwd="$PWD"
sid="${JFIELDS[1]:-}"
agent_id="${JFIELDS[2]:-}"
validated_pin="${NORTH_AGENT_ID:-}"
if [ -n "$validated_pin" ]; then
  pin_validation="$("$ACTOR_KEY" managed "$validated_pin" 2>/dev/null || true)"
  [ "${#pin_validation}" -eq 64 ] || validated_pin=""
fi
[ -n "$sid" ] || [ -n "$agent_id" ] || [ -n "$validated_pin" ] || exit 0

# Identity — same resolution order as north-on-tooluse (session cache → env → derived)
# so the marker key matches the id the listener/inbox use.
IDDIR="${XDG_RUNTIME_DIR:-/tmp}/north-agent-ids"
agent_key=""
[ -z "$agent_id" ] ||
  agent_key="$("$ACTOR_KEY" agent "$agent_id" 2>/dev/null || true)"
if [ "${#agent_key}" -eq 64 ] && [ -r "$IDDIR/$agent_key" ]; then
  identity_key="$agent_key"
elif [ -n "$sid" ]; then
  identity_key="$("$ACTOR_KEY" session "$sid" 2>/dev/null || true)"
elif [ -n "$validated_pin" ]; then
  identity_key="$("$ACTOR_KEY" managed "$validated_pin" 2>/dev/null || true)"
else
  exit 0
fi
[ "${#identity_key}" -eq 64 ] || exit 0
CACHE="${XDG_RUNTIME_DIR:-/tmp}/north-agent-ids/$identity_key"
ID=""
[ -r "$CACHE" ] && ID="$(cat "$CACHE" 2>/dev/null || true)"
[ -z "$ID" ] && ID="$validated_pin"
[ -z "$ID" ] && ID="native-$identity_key"

MARKDIR="${XDG_RUNTIME_DIR:-/tmp}/north-delegated"
mkdir -p "$MARKDIR" 2>/dev/null || true
mark_tmp="$MARKDIR/.$identity_key.$$.${RANDOM}.tmp"
if printf '%s\n%s\n' "$ID" "$(date +%s 2>/dev/null || echo 0)" \
    >"$mark_tmp" 2>/dev/null; then
  mv -f "$mark_tmp" "$MARKDIR/$identity_key" 2>/dev/null ||
    rm -f "$mark_tmp" 2>/dev/null || true
fi
exit 0
