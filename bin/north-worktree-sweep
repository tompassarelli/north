#!/usr/bin/env bash
# north-worktree-sweep — standalone orphan-worktree reaper.
# Reaps per-lane git worktrees (sdk/src/worktree.ts) of RESOLVED lanes: clean trees are
# removed, dirty trees are kept + surfaced as a `worktree_orphaned` fact for salvage.
# NEVER touches a live lane's tree, NEVER destroys WIP. See cli/worktree-sweep.clj.
#   north-worktree-sweep            # reap on the :7977 board
#   north-worktree-sweep --dry-run  # report what it WOULD reap, touch nothing
set -euo pipefail
BOARD="${NORTH_PORT:-7977}"
# Pass a leading numeric port through verbatim; otherwise inject the default board first.
if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
  exec bb "$HOME/code/north/cli/worktree-sweep.clj" "$@"
else
  exec bb "$HOME/code/north/cli/worktree-sweep.clj" "$BOARD" "$@"
fi
