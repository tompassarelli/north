#!/usr/bin/env bash
# north-log-split — Phase-2 replay-filter compaction for the log split.
# Partitions a single coordination log into a separate coordination.log +
# telemetry.log by the SAME log-for contract the coordinator routes writes by,
# preserving each line's :tx. Line-count conservation (coord+telem==total,
# dropped==0) is the invariant. Input log is read-only (rollback pre-image).
#   north-log-split [--dry-run|--execute] [--log PATH] [--coord PATH] [--telemetry PATH] [--force]
exec bb "$HOME/code/north/cli/log-split.clj" "$@"
