#lang beagle/js
(ns north.stream)

;; Reads an agent's activity stream into chat messages for the right panel.
;; Port of web/lib/north/stream.ex. Two sources, tried in order:
;;
;;   1. SDK stream-writer file ~/code/agent-data/agent-<handle>.stream.jsonl —
;;      one JSON event/line: assistant text -> {kind "text"}, tool_use ->
;;      {kind "tool", text name}, result -> {kind "result"}. Whole-file read
;;      (these stay small); an existing-but-empty file yields [] (NOT the
;;      fallback), matching File.read's {:ok, ""}.
;;   2. FALLBACK for interactive `cc-<repo>-<8hex>` handles (no stream file):
;;      the raw Claude Code transcript ~/.claude/projects/<*>/<8hex>*.jsonl,
;;      most-recently-modified match. Richer line format — see transcript-line.
;;
;; PERFORMANCE: transcripts exceed 100MB and the pane polls. We NEVER read the
;; whole transcript — seek to EOF minus ~512KB, drop the leading partial line,
;; parse only the tail. Last 200 messages returned regardless.
;;
;; Messages are records {kind, text} (kind: "user"|"text"|"tool"|"result") so
;; the JS renderer reads m.kind / m.text like the Elixir map.

;; Bun / JSON / Array / Math / RegExp are JS globals referenced only inside
;; js/quote below (raw emit), so no typed declare-extern is needed for them.

;; ---- raw-JS I/O + boundary predicates (js/quote — callback/type-tag shaped) -

(js/quote
  ;; ~/code/agent-data/agent-<handle>.stream.jsonl
  (export (function streamPath (handle)
    (const home (? (dot (dot process env) HOME) (dot (dot process env) HOME) ""))
    (return (tpl "" home "/code/agent-data/agent-" handle ".stream.jsonl"))))

  ;; JSON.parse -> null on malformed line instead of throwing.
  (export (function safeParse (s)
    (try (return (.parse JSON s))
      (catch e (return null)))))

  ;; JSON boundary is untyped: tag-check the decoded value.
  (export (function isStr (v) (return (=== (typeof v) "string"))))
  (export (function isNeStr (v)
    (return (? (=== (typeof v) "string") (!== v "") false))))
  (export (function isArr (v) (return (.isArray Array v))))
  (export (function isObj (v)
    (return (? (!== v null)
             (? (=== (typeof v) "object") (! (.isArray Array v)) false)
             false))))

  ;; last n elements (Enum.take(-n)); whole array when shorter.
  (export (function takeLast (arr n)
    (return (.slice arr (.max Math 0 (- (dot arr length) n))))))

  ;; Whole-file read; null when the file does not exist (File.read error).
  (export (async function readFileMaybe (path)
    (try
      (const f (.file Bun path))
      (const ok (await (.exists f)))
      (if (! ok) (return null))
      (return (await (.text f)))
      (catch e (return null)))))

  ;; Trailing ~512KB only; drop the leading partial line when we sliced mid-file.
  (export (async function tailLines (path)
    (try
      (const f (.file Bun path))
      (const ok (await (.exists f)))
      (if (! ok) (return (array)))
      (const size (dot f size))
      (const start (.max Math 0 (- size 524288)))
      (const data (await (.text (.slice f start size))))
      (const parts (.split data "\n"))
      (const lines (? (> start 0) (.slice parts 1) parts))
      (return (.filter lines (=> (l) (!== l ""))))
      (catch e (return (array))))))

  ;; cc-<repo>-<8hex> -> the 8-hex session-uuid prefix; null otherwise.
  (export (function sessionHex (handle)
    (const re (new RegExp "^cc-.+-([0-9a-f]{8})$"))
    (const m (.match handle re))
    (return (? m (bracket m 1) null))))

  ;; Full paths of ~/.claude/projects/<*>/<hex>*.jsonl (sync glob); [] on error.
  (export (function globPaths (hex)
    (try
      (const home (? (dot (dot process env) HOME) (dot (dot process env) HOME) ""))
      (const dir (tpl "" home "/.claude/projects"))
      (const G (dot Bun Glob))
      (const glob (new G (tpl "*/" hex "*.jsonl")))
      (const rels (.from Array (.scanSync glob dir)))
      (return (.map rels (=> (r) (tpl "" dir "/" r))))
      (catch e (return (array))))))

  ;; mtime in ms for most-recently-modified selection.
  (export (function mtimeOf (path)
    (return (dot (.file Bun path) lastModified)))))

(declare-extern streamPath [String -> String])
(declare-extern safeParse [String -> Any])
(declare-extern isStr [Any -> Bool])
(declare-extern isNeStr [Any -> Bool])
(declare-extern isArr [Any -> Bool])
(declare-extern isObj [Any -> Bool])
(declare-extern takeLast [Any Int -> Any])
(declare-extern readFileMaybe [String -> (Promise Any)])
(declare-extern tailLines [String -> (Promise Any)])
(declare-extern sessionHex [String -> Any])
(declare-extern globPaths [String -> Any])
(declare-extern mtimeOf [String -> Float])

;; ---- message shape ----------------------------------------------------------

(def max-msgs :- Int 200)

;; {kind, text} — record so JS reads m.kind / m.text (mirrors fram WriteResult).
(defrecord Message [(kind :- String) (text :- String)])

;; ---- SDK stream format ------------------------------------------------------

;; One assistant content block -> zero/one message; thinking & unknown dropped.
(defn block [(b :- Any)] :- Any
  (let [t (.-type b)]
    (cond
      (and (= t "text") (isNeStr (.-text b)))     [(->Message "text" (.-text b))]
      (and (= t "tool_use") (isStr (.-name b)))   [(->Message "tool" (.-name b))]
      :else [])))

(defn parse-line [(line :- String)] :- Any
  (let [j (safeParse line)]
    (cond
      (nil? j) []
      (and (= (.-type j) "assistant") (isArr (.-content j)))
        (.flatMap (.-content j) (fn [b] (block b)))
      (and (= (.-type j) "result") (isNeStr (.-result j)))
        [(->Message "result" (.-result j))]
      :else [])))

;; ---- Claude Code transcript fallback ----------------------------------------

;; A user turn is a genuine human message. Reject tool_result arrays (tool
;; output) and command/system-echo wrappers (<command-name>, <bash-input>, ...).
(defn user-turn [(content :- Any)] :- Any
  (cond
    (isStr content)
      (let [trimmed (.trimStart content)]
        (if (or (= trimmed "") (.startsWith trimmed "<"))
          []
          [(->Message "user" content)]))
    (isArr content)
      (if (.some content (fn [x] (and (isObj x) (= (.-type x) "tool_result"))))
        []
        (let [txt (.trim (.join (.map (.filter content
                                        (fn [x] (and (isObj x)
                                                     (= (.-type x) "text")
                                                     (isStr (.-text x)))))
                                      (fn [x] (.-text x)))
                                "\n"))]
          (if (= txt "") [] [(->Message "user" txt)])))
    :else []))

;; Map one transcript line to zero/more messages. Skips sidechains, meta/system
;; noise, thinking, tool_result turns, and <...>-wrapped command echoes.
(defn transcript-line [(line :- String)] :- Any
  (let [j (safeParse line)]
    (if (nil? j)
      []
      (cond
        (= (.-isSidechain j) true) []
        (and (= (.-type j) "assistant")
             (some? (.-message j))
             (isArr (.-content (.-message j))))
          (.flatMap (.-content (.-message j)) (fn [b] (block b)))
        (and (= (.-type j) "user") (= (.-isMeta j) true)) []
        (and (= (.-type j) "user") (some? (.-message j)))
          (user-turn (.-content (.-message j)))
        :else []))))

;; Most-recently-modified matching transcript, or nil.
(defn resolve-transcript [(hex :- String)] :- Any
  (let [paths (globPaths hex)]
    (if (= (.-length paths) 0)
      nil
      (reduce (fn [best p]
                (if (or (nil? best) (> (mtimeOf p) (mtimeOf best))) p best))
              nil paths))))

(defn transcript-messages [(handle :- String)] :- (Promise Any)
  (let [hex (sessionHex handle)]
    (if (nil? hex)
      []
      (let [path (resolve-transcript hex)]
        (if (nil? path)
          []
          (let [lines (js/await (tailLines path))]
            (takeLast (.flatMap lines (fn [l] (transcript-line l))) max-msgs)))))))

;; ---- public API -------------------------------------------------------------

(defn nonempty-lines [(body :- String)] :- Any
  (.filter (.split body "\n") (fn [l] (not (= l "")))))

;; Chat messages for an agent handle: array of {kind, text}.
(js/export (defn messages [(handle :- String)] :- (Promise Any)
  (let [body (js/await (readFileMaybe (streamPath handle)))]
    (if (some? body)
      (takeLast (.flatMap (nonempty-lines body) (fn [l] (parse-line l))) max-msgs)
      (js/await (transcript-messages handle))))))
