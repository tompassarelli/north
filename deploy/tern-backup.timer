# systemd timer — run the per-tenant facts.log backup daily.
#   sudo cp deploy/tern-backup.timer /etc/systemd/system/
#   sudo systemctl enable --now tern-backup.timer
[Unit]
Description=Daily Tern per-tenant facts.log backup

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
