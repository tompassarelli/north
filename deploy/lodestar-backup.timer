# systemd timer — run the per-tenant claims.log backup daily.
#   sudo cp deploy/lodestar-backup.timer /etc/systemd/system/
#   sudo systemctl enable --now lodestar-backup.timer
[Unit]
Description=Daily Lodestar per-tenant claims.log backup

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
