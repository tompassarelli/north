#lang beagle/clj
(ns north.projections
  "Read-only dependency-derived views over an indexed fact set (k/Index).
  O(threads) via the index, not O(threads * facts).")

(require fram.kernel :as k)
(require clojure.string :as str)

;; --- lifecycle vocab + derivation (moved out of the fram kernel) -------------
;; Lifecycle is DERIVED, never a stored status: the engine stores the facts but
;; north OWNS the derivation. terminal = resolved (outcome/abandoned/
;; superseded_by); withdrawn = a depends_on target that's suspect to depend on
;; (abandoned). The vocab mirrors the env contract bin/north exports
;; (FRAM_TERMINAL_PREDS / FRAM_WITHDRAWN_PREDS); the defaults ARE the north
;; lifecycle vocab. (The fram kernel still carries terminal-preds for the
;; coordinator's the-model §9 terminal-cascade — a separate daemon concern.)
(def terminal-preds :- (Vec String)
  (let [env :- Any (System/getenv "FRAM_TERMINAL_PREDS")]
    (if (and (some? env) (not (= env "")))
      (vec (str/split env #"\s+"))
      ["outcome" "abandoned" "superseded_by"])))

(def withdrawn-preds :- (Vec String)
  (let [env :- Any (System/getenv "FRAM_WITHDRAWN_PREDS")]
    (if (and (some? env) (not (= env "")))
      (vec (str/split env #"\s+"))
      ["abandoned"])))

(defn- any-of-i? [idx :- k/Index te :- String preds :- (Vec String)] :- Bool
  (loop [ps preds]
    (if (empty? ps) false
      (if (some? (k/one-i idx te (first ps))) true (recur (rest ps))))))

;; terminal = resolved: any of terminal-preds present (default outcome/abandoned/superseded_by).
(defn terminal-i? [idx :- k/Index te :- String] :- Bool
  (any-of-i? idx te terminal-preds))

;; withdrawn = canceled: any of withdrawn-preds present (default abandoned).
(defn withdrawn-i? [idx :- k/Index te :- String] :- Bool
  (any-of-i? idx te withdrawn-preds))

;; --- work-thread set (moved out of the fram kernel) --------------------------
;; WORK semantics, not a structural engine concern: which titled nodes are
;; actionable work vs grouping anchors. A grouping anchor is a node synthesized
;; only to be a relates_to target (former tags), never authored work — a valid
;; edge target (validation still sees it) but NOT actionable, so WORK projections
;; exclude it. The discriminator is STRUCTURAL: a titled, committed node carrying
;; NO work axis at all (no completion / activity / blocked / schedule /
;; composition / planning / accountability / chronology / navigation predicate).
(defn anchor-i? [idx :- k/Index te :- String] :- Bool
  (and (some? (k/one-i idx te "title"))
       (and (some? (k/one-i idx te "committed"))
            (and (not (terminal-i? idx te))
                 (and (nil? (k/one-i idx te "driver"))
                      (and (empty? (k/many-i idx te "depends_on"))
                           (and (nil? (k/one-i idx te "part_of"))
                                (and (nil? (k/one-i idx te "do_on"))
                                     (and (nil? (k/one-i idx te "valid_until"))
                                          (and (nil? (k/one-i idx te "estimate_hours"))
                                               (and (nil? (k/one-i idx te "lead"))
                                                    (and (empty? (k/many-i idx te "proposed_by"))
                                                         (and (nil? (k/one-i idx te "created_at"))
                                                              (and (nil? (k/one-i idx te "updated_at"))
                                                                   (nil? (k/one-i idx te "repo"))))))))))))))))

;; thread ids that are actual work (anchors excluded) — the basis for plate/
;; ready/next/leverage/agenda. validate keeps using k/thread-ids-i (sees anchors).
(defn work-thread-ids-i [idx :- k/Index] :- (Vec String)
  (filterv (fn [s :- String] :- Bool (not (anchor-i? idx s))) (k/thread-ids-i idx)))

;; DECIDED NON-GOAL (2026-06-18): do NOT rewrite ready/blocked as Datalog rules.
;; Measured on the live log (see leverage_probe.clj): the Datalog twin is ~2.3x MORE
;; code than these filterv's and forces a hand-listed predicate schema that duplicates
;; what k/Index already owns — a second source of truth that silently rots. Fact-native
;; logic is a win ONLY for recursive/relational derivation (the transitive leverage
;; closure below — proven output-identical, a real 1-rule-vs-loop win IF the reified
;; store is amortized across the whole layer), never for these flat filters.

;; Direct deps of te that are known threads and not yet terminal.
(defn incomplete-deps [idx :- k/Index te :- String] :- (Vec String)
  (filterv (fn [d :- String] :- Bool
             (and (some? (k/one-i idx d "title")) (not (terminal-i? idx d))))
           (k/many-i idx te "depends_on")))

(defn blocked? [idx :- k/Index te :- String] :- Bool
  (not (empty? (incomplete-deps idx te))))

;; Schedule axis (the-model §3/§7): a thread is DORMANT iff it carries a future
;; `do_on` (start date strictly after today) — it drops out of ready/next until
;; its date. A past/equal do_on is NOT dormant (it's live/overdue). today/before?
;; are threaded through callers exactly as staleness.bclj does (before? =
;; fram.rt/str-lt?); projections has no clock access of its own.
(defn dormant? [idx :- k/Index te :- String today :- String before? :- [String String -> Bool]] :- Bool
  (let [d (k/one-i idx te "do_on")]
    (and (some? d) (before? today d))))

;; --- driver LIVENESS is an explicit classifier input (not a stored fact) -----
;; A `driver` fact is an assignment, not proof of activity now: a pickup dead
;; since May still carries its driver. The ONE canonical classifier therefore
;; asks a `live?` predicate — [Index te -> Bool] — exactly as it asks today/
;; before? for the clock, rather than reading `driver` raw. Production callers
;; supply one lease+recency predicate for the entire command; tests inject a
;; deterministic predicate. `assigned?` remains orthogonal so grooming can show
;; stale assignments without inventing a second lifecycle.
(defn assigned? [idx :- k/Index te :- String] :- Bool
  (some? (k/one-i idx te "driver")))

;; The ONE shared precedence classifier (the-model §3): every single-bucket view
;; calls this, so two views can never disagree. EXACT precedence:
;;   terminal > blocked > active > dormant > ready > draft
;; `active` = a LIVE driver (per the caller's live? predicate); a parked/stale
;; driver is NOT active and falls through to its committed/schedule state.
;; `dormant` (a future do_on) dominates `ready`: a committed thread scheduled for
;; later is NOT pull-able now, so it drops out of ready/next EVERYWHERE (schedule
;; is an eligibility gate, not a display hint — the prior "committed dominates the
;; schedule" split let board call it ready while the work queue hid it).
(defn classify [idx :- k/Index te :- String today :- String before? :- [String String -> Bool] live? :- [k/Index String -> Bool]] :- String
  (cond
    [(terminal-i? idx te) "terminal"]
    [(blocked? idx te) "blocked"]
    [(live? idx te) "active"]
    [(dormant? idx te today before?) "dormant"]
    [(some? (k/one-i idx te "committed")) "ready"]
    [:else "draft"]))

;; ELIGIBILITY is DERIVED from the one classifier, never a parallel filter: a
;; thread is pull-able now iff it classifies `ready` (committed + unblocked + no
;; live driver + not scheduled-later). ready/next/board's READY bucket all reduce
;; to this predicate, so their eligibility sets are identical by construction.
(defn eligible? [idx :- k/Index te :- String today :- String before? :- [String String -> Bool] live? :- [k/Index String -> Bool]] :- Bool
  (= (classify idx te today before? live?) "ready"))

(defn ready [idx :- k/Index today :- String before? :- [String String -> Bool] live? :- [k/Index String -> Bool]] :- (Vec String)
  (filterv (fn [te :- String] :- Bool (eligible? idx te today before? live?))
           (work-thread-ids-i idx)))

;; One-line human/agent explanation of WHY a thread is (in)eligible — the state
;; plus its load-bearing reason. Shared by next (per-recommendation eligibility)
;; and grooming so the answer to "why isn't this in my queue?" is derived from the
;; same classifier, never re-explained ad hoc.
(defrecord Eligibility [state :- String eligible :- Bool reason :- String])

(defn explain [idx :- k/Index te :- String today :- String before? :- [String String -> Bool] live? :- [k/Index String -> Bool]] :- Eligibility
  (let [st (classify idx te today before? live?)]
    (->Eligibility
     st
     (= st "ready")
     (cond
       [(= st "terminal") "resolved (outcome/abandoned/superseded_by) — not workable"]
       [(= st "blocked") (str "waiting on " (count (incomplete-deps idx te)) " incomplete dependency(ies)")]
       [(= st "active") "a live driver is on it now — being worked, not pull-able"]
       [(= st "dormant") (str "scheduled for a future do_on (" (let [d (k/one-i idx te "do_on")] (if (some? d) d "?")) ") — dormant until then")]
       [(= st "ready") "committed, unblocked, no live driver, not scheduled-later — pull anytime"]
       [:else "uncommitted draft — decide + commit before it is work"]))))

(defn blocked [idx :- k/Index] :- (Vec String)
  (filterv (fn [te :- String] :- Bool
             (and (not (terminal-i? idx te)) (blocked? idx te)))
           (work-thread-ids-i idx)))

;; Derived condition of a work thread — delegates to the ONE precedence classifier
;; so plate text + json + the blocked command all agree. live? is threaded through
;; exactly as today/before? are (the caller owns the liveness notion).
(defn condition-i [idx :- k/Index te :- String today :- String before? :- [String String -> Bool] live? :- [k/Index String -> Bool]] :- String
  (classify idx te today before? live?))

;; Presentation: a deterministic, user-configurable emoji per condition. Engine
;; defaults here; any is overridden by a fact `@ui emoji_<condition> "<glyph>"`,
;; so the map is data the user owns — not the LLM's stochastic choice.
(defn- default-emoji [c :- String] :- String
  (cond
    [(= c "active") "🔵"]
    [(= c "ready") "🟢"]
    [(= c "blocked") "🔴"]
    [(= c "dormant") "🟡"]
    [(= c "terminal") "⚫"]
    [(= c "draft") "⚪"]
    [:else "•"]))

(defn condition-emoji [idx :- k/Index c :- String] :- String
  (let [o (k/one-i idx "@ui" (str "emoji_" c))]
    (if (some? o) o (default-emoji c))))

;; --- leverage: transitive reverse-dep walk over the prebuilt revdep index ----

(defn transitive-dependents [idx :- k/Index te :- String] :- (Vec String)
  (loop [frontier (k/dependents-i idx te)
         seen []]
    (if (empty? frontier)
      seen
      (let [x (first frontier)
            rest-f (vec (rest frontier))]
        (if (k/vec-contains? seen x)
          (recur rest-f seen)
          (recur (vec (concat rest-f (k/dependents-i idx x)))
                 (conj seen x)))))))

(defn leverage-score [idx :- k/Index te :- String] :- Int
  (count (filterv (fn [d :- String] :- Bool
                    (and (not (= d te)) (not (terminal-i? idx d))))
                  (transitive-dependents idx te))))
