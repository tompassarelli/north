+#[tokio::test]
+async fn managed_pre_tool_use_technical_failure_blocks_before_execution() -> Result<()> {
+    skip_if_host_windows!(Ok(()));
+    skip_if_no_network!(Ok(()));
+
+    let server = start_mock_server().await;
+    let home = Arc::new(TempDir::new().context("create managed hook test home")?);
+    let managed_dir = home.path().join("managed-hooks");
+    fs::create_dir_all(&managed_dir).context("create managed hook directory")?;
+    let script_path = managed_dir.join("fail_pre_tool.py");
+    let hook_log = managed_dir.join("fail_pre_tool.json");
+    fs::write(
+        &script_path,
+        format!(
+            r#"import json
+from pathlib import Path
+import sys
+
+payload = json.load(sys.stdin)
+Path(r"{hook_log}").write_text(json.dumps(payload), encoding="utf-8")
+sys.stderr.write("managed policy hook crashed\n")
+raise SystemExit(1)
+"#,
+            hook_log = hook_log.display(),
+        ),
+    )
+    .context("write failing managed PreToolUse hook")?;
+    let requirements = format!(
+        r#"allow_managed_hooks_only = true
+managed_hook_failure_mode = "block"
+
+[features]
+hooks = true
+
+[hooks]
+managed_dir = "{managed_dir}"
+
+[[hooks.PreToolUse]]
+matcher = "^Bash$"
+
+[[hooks.PreToolUse.hooks]]
+type = "command"
+command = "python3 {script_path}"
+timeout = 5
+"#,
+        managed_dir = managed_dir.display(),
+        script_path = script_path.display(),
+    );
+
+    let call_id = "managed-pretooluse-failure";
+    let marker = home.path().join("tool-side-effect-marker");
+    let secret_sentinel = "NORTH-SECRET-SENTINEL-0123456789-ABCDEFGHIJKLMNOPQRSTUVWXYZ-abcdefghijklmnopqrstuvwxyz-NORTH-SECRET-SENTINEL";
+    let command = format!("printf {secret_sentinel} > {}", marker.display());
+    let args = serde_json::json!({ "command": command });
+    let responses = mount_sse_sequence(
+        &server,
+        vec![
+            sse(vec![
+                ev_response_created("resp-1"),
+                ev_function_call(call_id, "shell_command", &serde_json::to_string(&args)?),
+                ev_completed("resp-1"),
+            ]),
+            sse(vec![
+                ev_response_created("resp-2"),
+                ev_assistant_message("msg-1", "managed hook denied dispatch"),
+                ev_completed("resp-2"),
+            ]),
+        ],
+    )
+    .await;
+
+    let test = test_codex()
+        .with_home(home)
+        .with_cloud_config_bundle(
+            CloudConfigBundleFixture::loader_with_enterprise_requirement(&requirements),
+        )
+        .build(&server)
+        .await?;
+
+    test.submit_turn_with_permission_profile(
+        "run the command guarded by the managed hook",
+        PermissionProfile::Disabled,
+    )
+    .await?;
+
+    let requests = responses.requests();
+    assert_eq!(requests.len(), 2);
+    let function_call_output = requests[1].function_call_output(call_id);
+    let output = function_call_output
+        .get("output")
+        .and_then(Value::as_str)
+        .expect("shell command output string");
+    assert!(
+        output.contains(
+            "managed PreToolUse hook failed; tool execution denied by administrator policy"
+        ),
+        "blocked result should surface the administrator failure policy",
+    );
+    assert!(
+        !output.contains(secret_sentinel),
+        "administrator failure result must not echo secret-bearing command content",
+    );
+    assert!(
+        !output.contains(&command),
+        "administrator failure result must remain bounded instead of logging the command",
+    );
+    assert!(hook_log.exists(), "managed PreToolUse hook should have run");
+    assert!(
+        !marker.exists(),
+        "tool handler must not run after a managed PreToolUse technical failure"
+    );
+
+    Ok(())
+}
